rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to fetch self metadata safely
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "19122007" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "admin") ||
        request.auth.token.email == "admin_19122007@redpacket.system"
      );
    }

    function isManager() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == "manager" && 
        getUserData().approvalStatus == "approved";
    }

    function isSponsor() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == "sponsor" && 
        getUserData().approvalStatus == "approved";
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.name is string && data.name.size() <= 150 &&
             data.email is string && data.email.size() <= 150 &&
             data.role is string &&
             data.approvalStatus is string;
    }

    // Rules for User accounts
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
                      request.resource.data.role == "pending" && 
                      request.resource.data.approvalStatus == "Waiting for Approval" &&
                      isValidUser(request.resource.data);
      allow update: if isAdmin() || (
                      isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.approvalStatus == resource.data.approvalStatus &&
                      isValidUser(request.resource.data)
                    );
      allow delete: if isAdmin();
    }

    // Rules for Red Packets
    match /packets/{packetId} {
      allow read: if isAdmin() || isManager() || (isSponsor() && resource.data.sponsorId == request.auth.uid);
      allow create: if isAdmin() || isManager();
      allow update: if isAdmin() || isManager() || (
                      isSponsor() && 
                      resource.data.sponsorId == request.auth.uid &&
                      request.resource.data.status in ["Pending", "Given", "Sharing Soon"] &&
                      request.resource.data.id == resource.data.id &&
                      request.resource.data.sponsorId == resource.data.sponsorId &&
                      request.resource.data.type == resource.data.type &&
                      request.resource.data.amount == resource.data.amount
                    );
      allow delete: if isAdmin();
    }

    // Rules for Invites
    match /invites/{inviteId} {
      allow read, write: if isAdmin() || isManager();
    }

    // Rules for Auditing activity logs
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // Rules for Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.read == true;
      allow delete: if isAdmin();
    }
  }
}
